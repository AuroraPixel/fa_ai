# FAL.ai API密钥，多个密钥用逗号分隔
FAL_KEYS=your-fal-ai-key-1,your-fal-ai-key-2

# MinIO配置
MINIO_ENDPOINT=s3.cortexai.info
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET=your-bucket-name

# 速率限制配置
# 格式: "rate/minutes"
# 默认值: "20/10" 表示每10分钟20次
# 如果值为 "0/0" 则表示无限制
RATE_LIMIT=20/10

# 免责声明配置
# 设置为 "false" 可禁用免责声明弹窗
SHOW_DISCLAIMER=true 